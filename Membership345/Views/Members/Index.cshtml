@using Membership345.Data
@model ApplicationUser

@{
    ViewData["Title"] = Model?.DisplayName ?? "Profil";
}

<div class="container my-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <!-- Profil Başlığı -->
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-body text-center py-5">
                    @if (!string.IsNullOrEmpty(Model?.ProfilePicture))
                    {
                        <img src="@Model.ProfilePicture" alt="Profil Resmi" class="rounded-circle mb-3" style="width: 120px; height: 120px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="rounded-circle mb-3 bg-secondary d-inline-flex align-items-center justify-content-center" style="width: 120px; height: 120px;">
                            <span class="text-white fs-3">
                                <i class="bi bi-person"></i>
                            </span>
                        </div>
                    }

                    <h2 class="mb-2">@Model?.DisplayName</h2>
                    @if (!string.IsNullOrEmpty(Model?.Bio))
                    {
                        <p class="text-muted mb-0">@Model.Bio</p>
                    }
                </div>
            </div>

            <!-- Kişisel Bilgiler -->
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-header bg-light border-bottom">
                    <h5 class="mb-0">Kişisel Bilgiler</h5>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-bold text-secondary">E-posta</label>
                                <p class="mb-0">@Model?.Email</p>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-bold text-secondary">Kullanıcı Adı</label>
                                <p class="mb-0">@Model?.UserName</p>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model?.Gender))
                        {
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold text-secondary">Cinsiyet</label>
                                    <p class="mb-0">@Model.Gender</p>
                                </div>
                            </div>
                        }

                        @if (Model?.DateOfBirth != default(DateTime))
                        {
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold text-secondary">Doğum Tarihi</label>
                                    <p class="mb-0">@Model.DateOfBirth.ToString("dd.MM.yyyy")</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Konum Bilgileri -->
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-header bg-light border-bottom">
                    <h5 class="mb-0">Konum Bilgileri</h5>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label fw-bold text-secondary">Ülke</label>
                                <p class="mb-0">@Model?.Country</p>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model?.City))
                        {
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold text-secondary">Şehir</label>
                                    <p class="mb-0">@Model.City</p>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model?.District))
                        {
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold text-secondary">İlçe</label>
                                    <p class="mb-0">@Model.District</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Bağlantılar -->
            @if (Model?.Links != null && Model.Links.Count > 0)
            {
                <div class="card mb-4 border-0 shadow-sm">
                    <div class="card-header bg-light border-bottom">
                        <h5 class="mb-0">Bağlantılar</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group list-group-flush">
                            @foreach (var link in Model.Links)
                            {
                                <a href="@link.Link" target="_blank" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                    <span>@link.Link</span>
                                    <span class="badge bg-primary rounded-pill">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </span>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- İşlem Butonları -->
            <div class="d-flex gap-2">
                <a href="#" class="btn btn-primary">Profili Düzenle</a>
                <a href="#" class="btn btn-secondary">Geri Dön</a>
            </div>
        </div>
    </div>
</div>
